FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1 \
    sox \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY scripts/qwen_tts_api.py /app/scripts/qwen_tts_api.py

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir \
    --index-url https://download.pytorch.org/whl/cu128 \
    torch \
    torchaudio \
    && pip install --no-cache-dir \
    qwen-tts \
    fastapi \
    "uvicorn[standard]" \
    soundfile \
    numpy

EXPOSE 8890

HEALTHCHECK --interval=30s --timeout=10s --start-period=180s --retries=20 \
    CMD curl -fsS http://localhost:8890/health | grep -q '"model_loaded":true' || exit 1

CMD ["python", "/app/scripts/qwen_tts_api.py"]
