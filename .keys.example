# Audify TTS Provider Configuration
# Copy this file to .keys and fill in your credentials
# The .keys file is gitignored and will not be committed

# =============================================================================
# TTS Provider Selection
# =============================================================================
# Options: kokoro, openai, aws, google, qwen
TTS_PROVIDER=kokoro

# =============================================================================
# Kokoro TTS (Local/Self-hosted)
# =============================================================================
# Base URL for Kokoro API (default: http://localhost:8887/v1)
KOKORO_API_URL=http://localhost:8887/v1

# =============================================================================
# OpenAI TTS
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model options: tts-1 (faster, lower quality), tts-1-hd (slower, higher quality)
OPENAI_TTS_MODEL=tts-1

# Voice options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=alloy

# =============================================================================
# AWS Polly
# =============================================================================
# Get credentials from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Region (e.g., us-east-1, eu-west-1)
AWS_REGION=us-east-1

# Voice options vary by language. Neural voices recommended:
# English: Joanna, Matthew, Ivy, Kendra, Kimberly, Salli, Joey, Justin, Kevin, Ruth, Stephen
# Spanish: Lupe, Pedro, Mia
# French: Lea, Remi
# See full list: https://docs.aws.amazon.com/polly/latest/dg/voicelist.html
AWS_POLLY_VOICE=Joanna

# Engine: standard or neural (neural recommended for better quality)
AWS_POLLY_ENGINE=neural

# =============================================================================
# Google Cloud Text-to-Speech
# =============================================================================
# Path to your service account credentials JSON file
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=

# Voice options vary by language. Neural2 voices recommended:
# English: en-US-Neural2-A through en-US-Neural2-J
# Spanish: es-ES-Neural2-A through es-ES-Neural2-F
# See full list: https://cloud.google.com/text-to-speech/docs/voices
GOOGLE_TTS_VOICE=en-US-Chirp-HD-F

# Language code for synthesis
GOOGLE_TTS_LANGUAGE_CODE=en-US

# =============================================================================
# Qwen-TTS (Local/Free)
# =============================================================================
# Qwen-TTS (Local FastAPI Wrapper)
# Run: python scripts/qwen_tts_api.py
# API exposed at: http://localhost:8890
# Qwen-TTS service runs on http://localhost:8890 (FastAPI wrapper around local Kokoro TTS logic)
QWEN_API_URL=http://localhost:8890

# Voice options: Vivian (Qwen-TTS)
QWEN_TTS_VOICE=Vivian

# =============================================================================
# LLM Configuration (for audiobook script generation)
# =============================================================================
# Ollama API URL (default: http://localhost:11434)
OLLAMA_API_URL=http://localhost:11434

# Default LLM model for audiobook generation
OLLAMA_MODEL=magistral:24b

# Default LLM model for translation
OLLAMA_TRANSLATION_MODEL=qwen3:30b
